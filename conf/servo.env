# servo_sensei configuration
# This file is auto-loaded by the app from the working directory.
# Shell environment variables always take precedence over values here.
# SERVO_PORT and SERVO_BAUD are required; SERVO_TIMEOUT_MS is optional (default: 100).

SERVO_PORT=/dev/ttyACM0
SERVO_BAUD=1000000
#SERVO_TIMEOUT_MS=100
